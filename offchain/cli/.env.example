# Cardano network the CLI runs against. Supported values: Preview, Mainnet.
# Every CLI command, every state directory (state/<network>_run_<id>/),
# every evidence directory (docs/milestones/evidence/m1-<network>-<id>/),
# and every step ID written into state JSONs is derived from this value.
CARDANO_NETWORK=Preview

# Blockfrost credentials for the selected network. Use a Preview project for
# CARDANO_NETWORK=Preview and a Mainnet project for CARDANO_NETWORK=Mainnet.
BLOCKFROST_PROJECT_ID=replace-with-network-matching-project-id

# Optional. Defaults are picked from CARDANO_NETWORK:
#   Preview  -> https://cardano-preview.blockfrost.io/api/v0
#   Mainnet  -> https://cardano-mainnet.blockfrost.io/api/v0
# Override only if you need a custom endpoint.
BLOCKFROST_API_URL=

# Wallet used to fund every transaction (admin = updater = funder).
# Generate via:  npm run cli -- wallet:create
# Then fund the resulting address on the matching network before running anything.
CARDANO_WALLET_SEED=
CARDANO_PRIVATE_KEY=

# Private key used to sign DIA OracleIntents (EVM/secp256k1). Required by
# run-all-cli.sh for non-interactive intent signing.
DIA_EVM_PRIVATE_KEY=

# Optional. Override the multi-provider tx confirmation pipeline. All four
# defaults give a ~9 min window across Blockfrost (Lucid SDK) -> Koios REST
# -> Blockfrost REST. Bump these when the network is congested or the
# provider is flaky. Set any of them to override a single stage; leave
# blank to use the defaults shown.
#
# TX_CONFIRMATION_PRIMARY_TIMEOUT_MS=180000    # Blockfrost (Lucid) hard timeout
# TX_CONFIRMATION_KOIOS_ATTEMPTS=60            # Koios poll attempts
# TX_CONFIRMATION_KOIOS_DELAY_MS=3000          # delay between Koios attempts
# TX_CONFIRMATION_BLOCKFROST_ATTEMPTS=30       # Blockfrost REST poll attempts
# TX_CONFIRMATION_BLOCKFROST_DELAY_MS=6000     # delay between Blockfrost REST attempts
