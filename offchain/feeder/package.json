{
  "name": "@diadata-org/dia-cardano-oracle-feeder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-running daemon that consumes DIA OracleIntentRegistry events and submits matching Cardano oracle updates. Architecturally aligned with diadata-org/Spectra-interoperability/services/bridge.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "feeder:dev": "tsx cmd/feeder/main.ts",
    "scan:pairs": "tsx scripts/scan-dia-intents.ts",
    "test": "node --import tsx/esm --test $(find src cmd -path '*/__tests__/*.test.ts' | tr '\\n' ' ')"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "viem": "^2.50.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@lucid-evolution/lucid": "^0.4.29",
    "@lucid-evolution/provider": "^0.1.90",
    "@lucid-evolution/wallet": "^0.1.72",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^12.10.0",
    "bip39": "^3.1.0",
    "libsodium-wrappers-sumo": "0.8.3",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3"
  },
  "overrides": {
    "libsodium-wrappers-sumo": "0.8.3",
    "libsodium-sumo": "0.8.3"
  }
}
