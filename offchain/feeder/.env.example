# DIA Cardano Oracle Feeder — environment variables.
#
# Design rule (see milestone-2-plan.md Annex D):
#
#   * The modular YAML config in `config/` is the single source of
#     truth for every public data point (chain ids, RPC URLs, WS URLs,
#     registry addresses, ABIs). It mirrors the upstream Spectra
#     Bridge schema (`services/bridge/config/`) verbatim — no
#     feeder-side fields invented.
#   * `.env` carries only:
#       - selectors (which network, which provider, log level, dry-run),
#       - secrets (project ids, wallet seeds, WS credentials, DSNs),
#       - daemon-only operational knobs that the Spectra Bridge also
#         exposes via env (API addr, metrics enabled, DB driver),
#       - informational values that Spectra does NOT have in its YAML
#         schema (the DIA explorer URL — used by future log/`/api/v1/prices`
#         link rendering).
#
# Variables intentionally absent (relative to offchain/cli/.env):
#   * `DIA_EVM_PRIVATE_KEY_*`   — only signers (the CLI) need it.
#   * `DIA_DOMAIN_NAME` / `_VERSION` — only signers + on-chain verifiers
#                                     need the EIP-712 domain.
#   * `DIA_SOURCE_CHAIN_ID_*`   — lives in
#                                 `config/infrastructure.<network>.yaml::source.chain_id`.
#   * `DIA_RPC_URL_*`          — lives in
#                                 `config/infrastructure.<network>.yaml::source.rpc_urls`.
#   * `DIA_WS_URL_*`           — lives in
#                                 `config/infrastructure.<network>.yaml::source.ws_url`.
#   * `DIA_REGISTRY_ADDRESS_*` — lives in
#                                 `config/contracts.yaml::<id>.address`.

# ============================================================================
# Active network selector (drives which `*_TESTNET` / `*_MAINNET` block is
# read AND which `infrastructure.<network>.yaml` the loader picks up).
# ============================================================================
CARDANO_NETWORK=Preview

# ============================================================================
# Cardano provider switch + tx confirmation timeouts (network-agnostic).
# Mirror offchain/cli/.env exactly.
# ============================================================================
CARDANO_PROVIDER=Blockfrost

# TX_CONFIRMATION_PRIMARY_TIMEOUT_MS=180000
# TX_CONFIRMATION_KOIOS_ATTEMPTS=60
# TX_CONFIRMATION_KOIOS_DELAY_MS=3000
# TX_CONFIRMATION_BLOCKFROST_ATTEMPTS=30
# TX_CONFIRMATION_BLOCKFROST_DELAY_MS=6000

# ============================================================================
# Cardano destination secrets — Testnet (Preview).
# ============================================================================
BLOCKFROST_PROJECT_ID_TESTNET=
BLOCKFROST_API_URL_TESTNET=https://cardano-preview.blockfrost.io/api/v0
KOIOS_API_URL_TESTNET=https://preview.koios.rest/api/v1

# Updater wallet that signs every Cardano oracle-update transaction on
# Preview. Routers reference these by env name via `private_key_env`.
CARDANO_WALLET_SEED_TESTNET=
CARDANO_PRIVATE_KEY_TESTNET=

# ============================================================================
# Cardano destination secrets — Mainnet.
# ============================================================================
BLOCKFROST_PROJECT_ID_MAINNET=
BLOCKFROST_API_URL_MAINNET=https://cardano-mainnet.blockfrost.io/api/v0
KOIOS_API_URL_MAINNET=https://api.koios.rest/api/v1

CARDANO_WALLET_SEED_MAINNET=
CARDANO_PRIVATE_KEY_MAINNET=

# ============================================================================
# DIA source — credentials only. Endpoints + addresses live in the YAML.
# ============================================================================
DIA_WS_CREDENTIAL_TESTNET=
DIA_WS_CREDENTIAL_MAINNET=

# Informational only — no counterpart in the Spectra Bridge YAML schema, so
# kept here. Used by future log/explorer link rendering. The feeder does not
# need these to scan or submit.
DIA_EXPLORER_URL_TESTNET=https://testnet-explorer.diadata.org
DIA_EXPLORER_URL_MAINNET=https://explorer.diadata.org

# ============================================================================
# Feeder daemon — names mirror diadata-org/Spectra-interoperability bridge
# .env.example where applicable. Network-agnostic except where suffixed.
# ============================================================================

# Persistence. Same key names as Spectra Bridge: DATABASE_DRIVER + DATABASE_DSN.
# We extend Spectra by also supporting SQLite (driver=sqlite, path-based
# instead of DSN) and by suffixing the DSN/path per network because the
# feeder may run two instances (one per network) on the same host.
DATABASE_DRIVER=sqlite   # sqlite | postgres

# When DATABASE_DRIVER=sqlite (default):
DATABASE_PATH_TESTNET=state/preview/feeder.sqlite
DATABASE_PATH_MAINNET=state/mainnet/feeder.sqlite

# When DATABASE_DRIVER=postgres:
# DATABASE_DSN_TESTNET=postgres://feeder:password@localhost:5432/feeder_preview?sslmode=disable
# DATABASE_DSN_MAINNET=postgres://feeder:password@localhost:5432/feeder_mainnet?sslmode=disable

# HTTP API (health, readiness, metrics, prices). Same key names as Spectra.
API_LISTEN_ADDR=:8080
API_ENABLE_CORS=false

# Prometheus metrics. Same key names as Spectra.
METRICS_ENABLED=true
METRICS_NAMESPACE=dia_bridge

# Run the pipeline (scanner, router, queue) but do not submit Cardano txs.
# Same key name as Spectra. Useful for QA and replays.
DRY_RUN=false

# Log level. Can also be overridden by the --log-level CLI flag.
# Same key name as Spectra.
LOG_LEVEL=info

# NOTE: the scanner start block is NOT an env var. It lives in
# config/infrastructure.<network>.yaml under `source.start_block`, the same
# way the upstream Spectra Bridge keeps it in `infrastructure.yaml`. The
# env-driven checkpoint is the persisted `chain_state.last_processed_block`
# in the database, which always wins over the YAML default once the feeder
# has seen at least one block.

# ============================================================================
# Docker runtime paths (env-only; not present in YAML schema).
# ============================================================================

# Absolute path to the directory containing compiled CLI JavaScript
# (index.js, core/, lib/transactions/). Defaults to <feeder>/../cli/src in
# dev mode (tsx). In the published Docker image this is set automatically
# to /app/cli/dist by the Dockerfile ENV directive. Only override if running
# the feeder outside Docker against a non-standard CLI checkout.
# Config key: CARDANO_FEEDER_CLI_DIST_ROOT (env-only).
# CARDANO_FEEDER_CLI_DIST_ROOT=/app/cli/dist

# Where the CLI writes (and the feeder reads) protocol/client state files.
# In Docker this is the `feeder-artifacts` named volume mounted at /artifacts.
# In bare-node dev mode it defaults to offchain/cli/state/.
# Config key: CARDANO_ARTIFACTS_ROOT (env-only).
# CARDANO_ARTIFACTS_ROOT=/artifacts
